# Required — async SQL Server connection string
# Format: mssql+aioodbc://sa:<password>@localhost:1433/<dbname>?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes
DATABASE_URL=mssql+aioodbc://sa:YourPassword@localhost:1433/todo_ai?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173
